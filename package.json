{
  "name": "atlas",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @atlas/web dev",
    "build": "pnpm -r build",
    "eval:all": "pnpm --filter @atlas/integrations eval:all",
    "eval:confirmed-mutation-recovery": "pnpm --filter @atlas/integrations eval:confirmed-mutation-recovery",
    "eval:conversation-context": "pnpm --filter @atlas/integrations eval:conversation-context",
    "eval:planner": "pnpm --filter @atlas/integrations eval:planner",
    "eval:router-confirmation": "pnpm --filter @atlas/integrations eval:router-confirmation",
    "eval:turn-router": "pnpm --filter @atlas/integrations eval:turn-router",
    "lint": "pnpm -r lint",
    "format": "pnpm biome format . --write",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "telegram:webhook:set": "bash scripts/set-telegram-webhook.sh",
    "db:test:start": "bash scripts/db-test-start.sh",
    "db:test:stop": "bash scripts/db-test-stop.sh",
    "db:test:reset": "bash scripts/db-test-reset.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8"
  }
}
